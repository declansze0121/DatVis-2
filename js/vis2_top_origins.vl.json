  "title": {
    "text": "Top 15 Green Coffee Bean Origins",
    "subtitle": "Australia, 2023 — UN Comtrade data. Use the dropdown to switch metrics.",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 700,
  "height": 460,
  "params": [
    {
      "name": "metric",
      "value": "value_million",
