  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3,
    "cursor": "pointer"
  },
  "encoding": {
    "y": {
      "field": "display_name",
      "type": "nominal",
      "sort": {"field": "selected_metric", "order": "descending"},
      "title": null,
      "axis": {
        "labelFontSize": 12
      }
    },
    "x": {
      "field": "selected_metric",
      "type": "quantitative",
      "title": {"expr": "metric == 'value_million' ? 'Import Value (USD M)' : metric == 'quantity_kg' ? 'Volume (kg)' : 'Price per kg (USD)'"},
      "axis": {
        "format": "~s"
      }
    },
    "color": {
      "field": "region",
      "type": "nominal",
      "title": "Region",
      "scale": {
        "domain": [
          "South America",
          "Central America",
          "Africa",
          "Asia",
          "Asia-Pacific",
          "Europe"
        ],
        "range": [
          "#2ecc71",
          "#e67e22",
          "#e74c3c",
          "#3498db",
          "#9b59b6",
          "#95a5a6"
        ]
      }
    },
    "opacity": {
      "condition": {"param": "bar_hover", "empty": true, "value": 1},
      "value": 0.35
    },
    "tooltip": [
      {
        "field": "display_name",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "value_million",
        "type": "quantitative",
        "title": "Import Value (USD M)",
        "format": ".2f"
      },
      {
        "field": "quantity_kg",
        "type": "quantitative",
        "title": "Volume (kg)",
        "format": ",.0f"
      },
      {
        "field": "price_per_kg_usd",
        "type": "quantitative",
        "title": "Price per kg (USD)",
        "format": ".2f"
      },
      {
        "field": "region",
        "type": "nominal",
        "title": "Region"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
