        "input": "select",
        "options": ["value_million", "quantity_kg", "price_per_kg_usd"],
        "labels": ["Import Value (USD M)", "Volume (kg)", "Price per kg (USD)"],
        "name": "View by: "
      }
    },
    {
      "name": "bar_hover",
      "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
    }
  ],
  "transform": [
    {"calculate": "datum[metric]", "as": "selected_metric"}
  ],
