  "params": [
    {
      "name": "region_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "South America", "Central America", "Africa", "Asia", "Asia-Pacific", "Europe", "North America"],
        "labels": ["All Regions", "South America", "Central America", "Africa", "Asia", "Asia-Pacific", "Europe", "North America"],
        "name": "Filter region: "
      }
    },
    {
      "name": "dot_hover",
      "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
    }
  ],
  "transform": [
    {"filter": "region_filter === 'All' || datum.region === region_filter"}
  ],
  "mark": {
    "type": "circle",
    "cursor": "pointer"
  },
  "encoding": {
    "x": {
      "field": "quantity_tonnes",
      "type": "quantitative",
      "title": "Quantity Imported (tonnes)",
      "scale": {
        "type": "log"
      },
      "axis": {
        "format": ",.0f"
      }
    },
    "y": {
      "field": "price_per_kg_usd",
      "type": "quantitative",
      "title": "Price per kg (USD)",
      "scale": {
        "zero": false
      }
    },
    "size": {
      "field": "value_1000usd",
      "type": "quantitative",
      "title": "Import Value ($1,000)",
      "scale": {
        "range": [
          50,
          1500
        ]
      }
    },
    "color": {
      "field": "region",
      "type": "nominal",
      "title": "Region",
      "scale": {
        "domain": [
          "South America",
          "Central America",
          "Africa",
          "Asia",
          "Asia-Pacific",
          "Europe",
          "North America"
        ],
        "range": [
          "#2ecc71",
          "#e67e22",
          "#e74c3c",
          "#3498db",
          "#9b59b6",
          "#95a5a6",
          "#1abc9c"
        ]
      }
    },
    "opacity": {
      "condition": {"param": "dot_hover", "empty": true, "value": 0.9},
      "value": 0.15
    },
    "tooltip": [
      {
        "field": "display_name",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "price_per_kg_usd",
        "type": "quantitative",
        "title": "Price/kg (USD)",
        "format": ".2f"
      },
      {
        "field": "quantity_tonnes",
        "type": "quantitative",
        "title": "Quantity (tonnes)",
        "format": ",.1f"
      },
      {
        "field": "value_1000usd",
        "type": "quantitative",
        "title": "Value ($1,000)",
        "format": ",.0f"
      },
      {
        "field": "region",
        "type": "nominal",
        "title": "Region"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
